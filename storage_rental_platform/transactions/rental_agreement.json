      "default": "Draft",
      "in_list_view": 1
    },
    {
      "fieldname": "terms_section",
      "label": "Terms",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "monthly_rent",
      "label": "Monthly Rent",
