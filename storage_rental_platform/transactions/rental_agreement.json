    },
    {
      "fieldname": "id_proof",
      "label": "ID Proof",
      "fieldtype": "Attach"
    },
    {
      "fieldname": "address_proof",
      "label": "Address Proof",
      "fieldtype": "Attach"
    },
    {
      "fieldname": "notes_section",
      "label": "Notes",
      "fieldtype": "Section Break"
    },
    {
      "fieldname": "notes",
      "label": "Notes",
      "fieldtype": "Text Editor"
    }
