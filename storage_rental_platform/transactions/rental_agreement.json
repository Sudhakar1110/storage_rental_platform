      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "security_deposit",
      "label": "Security Deposit",
      "fieldtype": "Currency",
      "reqd": 1
    },
    {
      "fieldname": "total_rent",
      "label": "Total Rent",
      "fieldtype": "Currency",
      "in_list_view": 1
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
