      "in_list_view": 1
    },
    {
      "fieldname": "min_height",
      "label": "Minimum Height (ft)",
      "fieldtype": "Float"
    },
    {
      "fieldname": "max_height",
      "label": "Maximum Height (ft)",
      "fieldtype": "Float"
    },
    {
      "fieldname": "is_active",
      "label": "Is Active",
      "fieldtype": "Check",
      "default": "1",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "Storage Administrator",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
