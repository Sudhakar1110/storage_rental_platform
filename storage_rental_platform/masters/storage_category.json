{
  "doctype": "DocType",
  "name": "Storage Category",
  "module": "storage_rental_platform",
  "autoname": "field:category_name",
  "is_submittable": 0,
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "category_name",
